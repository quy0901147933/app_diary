SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
SUPABASE_PHOTO_BUCKET=photos

GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
# Optional per-workload override. Falls back to GEMINI_MODEL when blank.
GEMINI_VISION_MODEL=gemini-2.5-flash-lite
GEMINI_BLOG_MODEL=gemini-2.5-flash
GEMINI_CHAT_MODEL=gemini-2.5-pro
# Auto-fallback chain when primary chat model hits quota/503 (comma-separated)
GEMINI_CHAT_FALLBACK_MODELS=gemini-2.5-flash,gemini-2.5-flash-lite

# Local dev: liệt kê các origin cụ thể.
# Production (Render/Railway/Fly): đặt "*" — JWT đã bảo vệ mọi route nên an toàn cho personal use.
CORS_ORIGINS=http://localhost:8081,http://localhost:19006,exp://
LOG_LEVEL=info

# PORT do platform tự inject (Render/Railway/Fly). Local mặc định 8000.
# PORT=8000

# Daily packaging (Ký ức đã đóng gói) — auto blog at this hour, in this TZ
DAILY_PACKAGE_HOUR=22
SCHEDULER_TIMEZONE=Asia/Ho_Chi_Minh
