# Mobile (Expo) — only EXPO_PUBLIC_* are bundled into the app.
# IMPORTANT: các biến này được "bake" vào bundle tại build time,
# nên đổi giá trị → phải build lại app (eas build hoặc expo start).
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Local dev: http://<LAN-IP>:8000 (đảm bảo iPhone & Mac cùng wifi)
# Production (qua 4G/5G): URL của backend live, ví dụ:
#   https://lumina-diary-backend.onrender.com
# EAS Build sẽ override biến này từ profile env trong eas.json.
EXPO_PUBLIC_AI_API_BASE_URL=http://localhost:8000

# Google OAuth — flow đi qua Supabase Auth (signInWithOAuth)
# Không cần đặt client id/secret trên client; cấu hình ở Supabase Dashboard.
# Xem docs/google-signin-setup.md để biết các bước cấu hình.
